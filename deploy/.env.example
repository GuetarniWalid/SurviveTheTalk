# AI Services
SONIOX_API_KEY=
OPENROUTER_API_KEY=
CARTESIA_API_KEY=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Auth
# JWT_SECRET MUST be >= 32 chars in production. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Resend (email delivery for the 6-digit auth code).
# survivethetalk.com is DNS-verified in Resend (DKIM/SPF/DMARC live), so any
# *@survivethetalk.com address works as sender. `noreply@` is a label, not a
# real mailbox — replies bounce silently (expected).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@survivethetalk.com
RESEND_FROM_NAME=surviveTheTalk

# Database
DATABASE_PATH=/opt/survive-the-talk/data/db.sqlite

# Runtime: development | test | production
# In production the server refuses to boot if JWT_SECRET is < 32 chars.
ENVIRONMENT=development
