# AI Services
SONIOX_API_KEY=
OPENROUTER_API_KEY=

# Story 6.13 Phase 4b (2026-05-26) — TTS provider switch. Default is
# `elevenlabs` because Cartesia's WebSocket has a reproducible
# multi-frame stall bug (see call 156/157 logs + Cartesia support
# thread). Flip to `cartesia` if Cartesia ships a fix and you want
# to validate on the Sonic-3 voice. Either provider needs its
# matching API key + voice id below; runtime validation in
# `pipeline/tts_factory.py` raises at process start if the chosen
# provider's required fields are empty.
TTS_PROVIDER=elevenlabs

# Cartesia (kept in the codebase for rollback / Cartesia support
# reproduction). Set even if TTS_PROVIDER=elevenlabs — leaving it
# empty would break tests that exercise `Settings(...)` construction.
CARTESIA_API_KEY=

# ElevenLabs Flash v2.5 — only required when TTS_PROVIDER=elevenlabs.
# Generate the API key at https://elevenlabs.io/app/settings/api-keys.
# Pick a voice for Tina (tired British female waitress) at
# https://elevenlabs.io/app/voice-library (starting candidates:
# Alice, Charlotte, Dorothy) and paste its id as ELEVENLABS_VOICE_ID.
# Optional: pin a specific model snapshot via ELEVENLABS_MODEL
# (default `eleven_flash_v2_5` — lowest TTFA ~75 ms).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_flash_v2_5

# Story 6.9b — Classifier provider key (Groq, post-2026-05-22 migration).
# Required for prod — `bot.py` constructs `ExchangeClassifier(api_key=
# settings.groq_api_key)`. Get one at https://console.groq.com/keys.
# Free tier (6000 TPM) is sufficient for MVP traffic (~5 classify per call
# × ~5 calls/day × 100 users = 500/day, well under the per-minute cap).
GROQ_API_KEY=

# Story 6.9b — Classifier model id override (default Settings.classifier_model
# = `llama-3.3-70b-versatile`, the post-bench winner). Used for rollback
# to Qwen (`qwen/qwen3.5-flash-02-23`) without a code release if Groq has
# an incident. Leave commented to use the default Groq Llama 3.3 70B.
# CLASSIFIER_MODEL=

# Story 6.9b — Benchmark-only API keys for the
# scripts/benchmark_classifier.py harness on the dev machine. NOT needed
# in prod — the bench is dev-only and the winning provider's key is
# above (GROQ_API_KEY).
CEREBRAS_API_KEY=
ANTHROPIC_API_KEY=

# Story 6.9b — Lever 1 exploration (direct Alibaba DashScope, skip
# OpenRouter proxy). Benched 2026-05-22 — provided no gain over
# OpenRouter (both ~590 ms p50 from VPS; the bottleneck was Qwen-being-
# hosted-in-Singapore, not OpenRouter overhead). Kept as a slot for any
# future re-bench. NOT needed in prod since the migration landed on Groq.
DASHSCOPE_API_KEY=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Auth
# JWT_SECRET MUST be >= 32 chars in production. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Resend (email delivery for the 6-digit auth code).
# survivethetalk.com is DNS-verified in Resend (DKIM/SPF/DMARC live), so any
# *@survivethetalk.com address works as sender. `noreply@` is a label, not a
# real mailbox — replies bounce silently (expected).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@survivethetalk.com
RESEND_FROM_NAME=surviveTheTalk

# Database
DATABASE_PATH=/opt/survive-the-talk/data/db.sqlite

# Runtime: development | test | production
# In production the server refuses to boot if JWT_SECRET is < 32 chars.
ENVIRONMENT=development

# Story 6.13 — Cartesia silent-stall investigation tooling. When set to "1",
# `bot.py` swaps `CartesiaTTSService` for `InstrumentedCartesiaTTSService`
# which logs every WebSocket send + recv + audio-context lifecycle transition
# under the `[CART-INSTR]` prefix. Used to capture the freeze pattern on
# Pixel 9 Pro XL during smoke runs. Leave OFF (commented or =0) in prod
# once the bug is diagnosed — the watchdog from Story 6.13 AC1 is the
# always-on safety net; this is the diagnostic. See
# `server/pipeline/cartesia_instrumented.py` for details.
# CARTESIA_INSTRUMENT=0

# Story 6.13 Phase 4 — Cartesia multi-frame freeze FIX (Option A). When
# set to "1", `bot.py` uses `FreshContextCartesiaTTSService` which sends
# each sentence as a single-shot Cartesia request (fresh `context_id` +
# `continue=False`) instead of accumulating multiple sends on the same
# context. Eliminates the 30%-rate freeze surfaced during Story 6.9b's
# smoke gate (root cause: Cartesia hangs on rapid same-context sends).
# Takes precedence over `CARTESIA_INSTRUMENT` (`FreshContext` inherits
# the instrumentation). Validate on a smoke run with multi-sentence
# Tina responses; if confirmed stable, a follow-up story promotes this
# to the default + drops the env gate.
# CARTESIA_FRESH_CTX=0
