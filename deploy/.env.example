# AI Services
SONIOX_API_KEY=
OPENROUTER_API_KEY=

# Story 6.14 (2026-05-30) — TTS provider switch. Default is now
# `cartesia`: the 2026-05-26 multi-frame freeze that drove us to
# ElevenLabs was a RESOLVED Cartesia platform incident (both repros were
# in the incident window), and on-device A/B found Cartesia's smaller
# audio frames play far smoother under network jitter (no "voix
# rallongée"). ElevenLabs Flash v2.5 is the LAST-RESORT fallback (lower
# raw TTFA but stretches more under jitter). Flip with
# `TTS_PROVIDER=elevenlabs`. Either provider needs its matching API key +
# voice id below; runtime validation in `pipeline/tts_factory.py` raises
# at process start if the chosen provider's required fields are empty.
TTS_PROVIDER=cartesia

# Cartesia — REQUIRED now (the default provider). Sonic-3 voice.
CARTESIA_API_KEY=

# ElevenLabs Flash v2.5 — only required when TTS_PROVIDER=elevenlabs
# (the last-resort fallback).
# Generate the API key at https://elevenlabs.io/app/settings/api-keys.
# Pick a voice for Tina (tired British female waitress) at
# https://elevenlabs.io/app/voice-library (starting candidates:
# Alice, Charlotte, Dorothy) and paste its id as ELEVENLABS_VOICE_ID.
# Optional: pin a specific model snapshot via ELEVENLABS_MODEL
# (default `eleven_flash_v2_5` — lowest TTFA ~75 ms).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_flash_v2_5

# Story 6.9b — Classifier provider key (Groq, post-2026-05-22 migration).
# Required for prod — `bot.py` constructs `ExchangeClassifier(api_key=
# settings.groq_api_key)`. Get one at https://console.groq.com/keys.
# Free tier (6000 TPM) is sufficient for MVP traffic (~5 classify per call
# × ~5 calls/day × 100 users = 500/day, well under the per-minute cap).
GROQ_API_KEY=

# Story 6.9b — Classifier model id override (default Settings.classifier_model
# = `llama-3.3-70b-versatile`, the post-bench winner). Used for rollback
# to Qwen (`qwen/qwen3.5-flash-02-23`) without a code release if Groq has
# an incident. Leave commented to use the default Groq Llama 3.3 70B.
# CLASSIFIER_MODEL=

# Story 6.9b — Benchmark-only API keys for the
# scripts/benchmark_classifier.py harness on the dev machine. NOT needed
# in prod — the bench is dev-only and the winning provider's key is
# above (GROQ_API_KEY).
CEREBRAS_API_KEY=
ANTHROPIC_API_KEY=

# Story 6.9b — Lever 1 exploration (direct Alibaba DashScope, skip
# OpenRouter proxy). Benched 2026-05-22 — provided no gain over
# OpenRouter (both ~590 ms p50 from VPS; the bottleneck was Qwen-being-
# hosted-in-Singapore, not OpenRouter overhead). Kept as a slot for any
# future re-bench. NOT needed in prod since the migration landed on Groq.
DASHSCOPE_API_KEY=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Story 6.14 AC2 — receiver-side jitter buffer (the "voix rallongée" fix).
# Minimum subscriber playout delay (ms) attached to BOTH call tokens'
# LiveKit room config (`pipeline/livekit_tokens.py`). The SFU then emits
# the `playout-delay` RTP extension so the phone's NetEq keeps a bigger
# jitter buffer and stops time-stretching Tina's voice under bursty
# (jittery) packet arrival. Trades a small fixed latency for smooth
# playback — keep the SMALLEST value that kills the stretching (PRD
# ceiling = 2 s perceived). Set 0 to disable the knob (rollback). Default
# 200; tuned on the Pixel 9 smoke gate.
# LIVEKIT_MIN_PLAYOUT_DELAY_MS=200

# Auth
# JWT_SECRET MUST be >= 32 chars in production. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Resend (email delivery for the 6-digit auth code).
# survivethetalk.com is DNS-verified in Resend (DKIM/SPF/DMARC live), so any
# *@survivethetalk.com address works as sender. `noreply@` is a label, not a
# real mailbox — replies bounce silently (expected).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@survivethetalk.com
RESEND_FROM_NAME=surviveTheTalk

# Database
DATABASE_PATH=/opt/survive-the-talk/data/db.sqlite

# Runtime: development | test | production
# In production the server refuses to boot if JWT_SECRET is < 32 chars.
ENVIRONMENT=development

# Story 6.13 — Cartesia verbose investigation tooling. When set to "1",
# the factory swaps the default `ErrorLoggingCartesiaTTSService` for
# `InstrumentedCartesiaTTSService`, which logs every WebSocket send +
# recv + audio-context lifecycle transition under the `[CART-INSTR]`
# prefix. Used to capture a freeze pattern on Pixel 9 Pro XL during smoke
# runs. Leave OFF (commented or =0) in prod — the default service
# already surfaces Cartesia's documented `type=error` schema at WARNING,
# and the Story 6.13 AC1 watchdog is the always-on safety net. See
# `server/pipeline/cartesia_instrumented.py`.
# CARTESIA_INSTRUMENT=0
#
# (`CARTESIA_FRESH_CTX` was removed in Story 6.14 — Cartesia confirmed the
# fresh-context-per-sentence workaround was unnecessary/counter-productive.)
