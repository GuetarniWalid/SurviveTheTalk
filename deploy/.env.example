# AI Services
SONIOX_API_KEY=
OPENROUTER_API_KEY=
CARTESIA_API_KEY=

# Story 6.9b — Classifier provider key (Groq, post-2026-05-22 migration).
# Required for prod — `bot.py` constructs `ExchangeClassifier(api_key=
# settings.groq_api_key)`. Get one at https://console.groq.com/keys.
# Free tier (6000 TPM) is sufficient for MVP traffic (~5 classify per call
# × ~5 calls/day × 100 users = 500/day, well under the per-minute cap).
GROQ_API_KEY=

# Story 6.9b — Classifier model id override (default Settings.classifier_model
# = `llama-3.3-70b-versatile`, the post-bench winner). Used for rollback
# to Qwen (`qwen/qwen3.5-flash-02-23`) without a code release if Groq has
# an incident. Leave commented to use the default Groq Llama 3.3 70B.
# CLASSIFIER_MODEL=

# Story 6.9b — Benchmark-only API keys for the
# scripts/benchmark_classifier.py harness on the dev machine. NOT needed
# in prod — the bench is dev-only and the winning provider's key is
# above (GROQ_API_KEY).
CEREBRAS_API_KEY=
ANTHROPIC_API_KEY=

# Story 6.9b — Lever 1 exploration (direct Alibaba DashScope, skip
# OpenRouter proxy). Benched 2026-05-22 — provided no gain over
# OpenRouter (both ~590 ms p50 from VPS; the bottleneck was Qwen-being-
# hosted-in-Singapore, not OpenRouter overhead). Kept as a slot for any
# future re-bench. NOT needed in prod since the migration landed on Groq.
DASHSCOPE_API_KEY=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Auth
# JWT_SECRET MUST be >= 32 chars in production. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Resend (email delivery for the 6-digit auth code).
# survivethetalk.com is DNS-verified in Resend (DKIM/SPF/DMARC live), so any
# *@survivethetalk.com address works as sender. `noreply@` is a label, not a
# real mailbox — replies bounce silently (expected).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@survivethetalk.com
RESEND_FROM_NAME=surviveTheTalk

# Database
DATABASE_PATH=/opt/survive-the-talk/data/db.sqlite

# Runtime: development | test | production
# In production the server refuses to boot if JWT_SECRET is < 32 chars.
ENVIRONMENT=development
